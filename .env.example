# Groq — LLM inference API. Get a key from https://console.groq.com
GROQ_API_KEY=gsk_your_key_here

# Qdrant — local Docker default. For Qdrant Cloud, use the cluster URL.
QDRANT_URL=http://localhost:6333

# Leave empty when running Qdrant locally via Docker.
# Set this only when using Qdrant Cloud.
QDRANT_API_KEY=
